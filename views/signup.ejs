<section id="signup-section">
  <div class="container">
    <h2>Create Your Account</h2>
    <p class="signup-subtitle">Join our secure supply chain financing platform</p>
    
    <form id="signup-form">
      <!-- Role Selection -->
      <div class="form-section">
        <h3>Select Your Role</h3>
        <div class="form-group">
          <label>I am a: <span class="required">*</span></label>
          <select id="signup-role" required>
            <option value="">Choose your role</option>
            <option value="SUPPLIER">Supplier - I need financing for my orders</option>
            <option value="LENDER">Lender - I want to finance supply chain orders</option>
          </select>
          <small>Note: Admin accounts are created internally</small>
        </div>
      </div>

      <!-- Personal Information -->
      <div class="form-section">
        <h3>Personal Information</h3>
        <div class="form-row">
          <div class="form-group">
            <label>Full Name <span class="required">*</span></label>
            <input type="text" id="signup-name" required minlength="2" maxlength="100" placeholder="e.g., John Doe">
          </div>
          <div class="form-group">
            <label>Email Address <span class="required">*</span></label>
            <input type="email" id="signup-email" required placeholder="e.g., john@company.com">
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label>Phone Number <span class="required">*</span></label>
            <input type="tel" id="signup-phone" required pattern="[0-9]{10,15}" placeholder="e.g., 9876543210" title="Enter 10 to 15 digits only (no spaces or special characters)">
            <small>Format: 10-15 digits only (e.g., 9876543210)</small>
          </div>
        </div>
      </div>

      <!-- Password Section -->
      <div class="form-section">
        <h3>Account Security</h3>
        <div class="form-row">
          <div class="form-group">
            <label>Password <span class="required">*</span></label>
            <input type="password" id="signup-password" required minlength="6">
            <small>Minimum 6 characters</small>
          </div>
          <div class="form-group">
            <label>Confirm Password <span class="required">*</span></label>
            <input type="password" id="signup-confirm-password" required minlength="6">
          </div>
        </div>
      </div>

      <!-- Business Information -->
      <div class="form-section">
        <h3>Business Information</h3>
        <div class="form-row">
          <div class="form-group">
            <label>Business Name <span class="required">*</span></label>
            <input type="text" id="signup-business-name" required placeholder="e.g., ABC Enterprises Pvt Ltd">
          </div>
          <div class="form-group">
            <label>Business Type <span class="required">*</span></label>
            <select id="signup-business-type" required>
              <option value="">Select business type</option>
              <option value="SOLE_PROPRIETORSHIP">Sole Proprietorship</option>
              <option value="PARTNERSHIP">Partnership</option>
              <option value="PRIVATE_LIMITED">Private Limited Company</option>
              <option value="PUBLIC_LIMITED">Public Limited Company</option>
              <option value="LLP">Limited Liability Partnership (LLP)</option>
            </select>
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label>Tax ID / GST Number <span class="required">*</span></label>
            <input type="text" id="signup-tax-id" required placeholder="e.g., 29ABCDE1234F1Z5">
            <small>Enter your GST number or Tax ID</small>
          </div>
          <div class="form-group">
            <label>Business Registration Number</label>
            <input type="text" id="signup-registration-number">
          </div>
        </div>
      </div>

      <!-- Address Information -->
      <div class="form-section">
        <h3>Business Address</h3>
        <div class="form-row">
          <div class="form-group">
            <label>Street Address <span class="required">*</span></label>
            <input type="text" id="signup-street" required placeholder="e.g., 123 Main Street, Building A">
          </div>
          <div class="form-group">
            <label>City <span class="required">*</span></label>
            <input type="text" id="signup-city" required placeholder="e.g., Mumbai">
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label>State / Province <span class="required">*</span></label>
            <input type="text" id="signup-state" required placeholder="e.g., Maharashtra">
          </div>
          <div class="form-group">
            <label>PIN Code / ZIP <span class="required">*</span></label>
            <input type="text" id="signup-pincode" required pattern="[0-9]{6}" placeholder="e.g., 400001" title="Enter 6-digit PIN code">
            <small>Format: 6 digits (e.g., 400001)</small>
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label>Country <span class="required">*</span></label>
            <input type="text" id="signup-country" required value="India">
          </div>
        </div>
      </div>

      <!-- Bank Details -->
      <div class="form-section">
        <h3>Bank Details</h3>
        <div class="form-row">
          <div class="form-group">
            <label>Bank Account Number <span class="required">*</span></label>
            <input type="text" id="signup-account-number" required pattern="[0-9]{9,18}" placeholder="e.g., 123456789012" title="Enter 9 to 18 digit account number">
            <small>Enter 9-18 digit account number</small>
          </div>
          <div class="form-group">
            <label>IFSC Code <span class="required">*</span></label>
            <input type="text" id="signup-ifsc" required pattern="[A-Z]{4}0[A-Z0-9]{6}" placeholder="e.g., SBIN0001234" title="Format: 4 letters, followed by 0, then 6 characters (e.g., SBIN0001234)" style="text-transform: uppercase;">
            <small>Format: XXXX0XXXXXX (e.g., SBIN0001234)</small>
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label>Bank Name <span class="required">*</span></label>
            <input type="text" id="signup-bank-name" required placeholder="e.g., State Bank of India">
          </div>
          <div class="form-group">
            <label>Account Holder Name <span class="required">*</span></label>
            <input type="text" id="signup-account-holder" required placeholder="e.g., John Doe">
            <small>Name as per bank records</small>
          </div>
        </div>
      </div>

      <!-- Terms and Verification -->
      <div class="form-section">
        <h3>Terms & Conditions</h3>
        <div class="checkbox-group">
          <label>
            <input type="checkbox" id="signup-terms" required>
            I agree to the <a href="#" class="auth-link">Terms of Service</a> and <a href="#" class="auth-link">Privacy Policy</a>
          </label>
        </div>
        <div class="checkbox-group">
          <label>
            <input type="checkbox" id="signup-verify" required>
            I certify that all information provided is accurate and I understand that false information may result in account suspension
          </label>
        </div>
        <div class="checkbox-group">
          <label>
            <input type="checkbox" id="signup-kyc" required>
            I consent to KYC verification and background checks as required by platform policies
          </label>
        </div>
      </div>

      <button type="submit" class="signup-btn">Create Account</button>
      <div id="signup-error" class="error"></div>
    </form>
    
    <div class="auth-footer">
      <p>Already have an account? <a href="/" class="auth-link">Login Here</a></p>
    </div>
  </div>
</section>
